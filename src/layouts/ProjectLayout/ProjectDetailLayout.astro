---
import Layout from '../Layout.astro';
import HeaderNonSticky from '../../components/home/HeaderNonSticky.astro';
import SocialFooter from '../../components/home/SocialFooter.astro';
import LocalImage from '../../components/LocalImage.astro';
import ImageCarousel from '../../components/ImageCarousel.tsx';
import MapboxMap from '../../components/MapboxMap.tsx';
import ChatWrapper from '../../components/ChatWrapper.astro';
import BrochureDownloader from '../../components/BrochureDownloader';

function getProjectLocation(projectId: string): string {
  const locationMap: Record<string, string> = {
    'amitie': 'Este', 'filia': 'Este', 'lagun': 'Este', 'provenza': 'Este',
    'verona': 'Oeste', 'siena': 'Oeste', 'piamonte': 'Oeste', 'solaris': 'Oeste',
    'athas': 'Centro', 'alai': 'Centro', 'astre': 'Centro'
  };
  return locationMap[projectId] || 'Centro';
}

export interface Props {
  project: {
    id: string;
    name: string;
    logo2: string;
    propertyType: string;
    location: string;
    slogan: string;
    address: string;
    description: string;
    size: string;
    bedrooms: string;
    bathrooms: string;
    price: string;
    coverImage: string;
    brochureFile: string;
    buttonText: string;
    features: { icon: string; text: string; }[];
    gallery: string[];
    amenidades?: string[];
    videoFile: string;
    videoThumbnail: string;
    mapImage: string;
    mapsUrl: string;
    pipedriveFormUrl: string;
  };
}

const { project } = Astro.props;

const projectFolder = project.id.charAt(0).toUpperCase() + project.id.slice(1);
const projectLocation = getProjectLocation(project.id);
const imageBasePath = `/Proyectos/${projectLocation}/${projectFolder}`;

const videoMap: Record<string, string> = {
  'athas': '/Videos/Video_proyecto_-_Athas_ptboqr.mp4',
  'alai': '/Videos/Video_proyecto_Alai_nmabjm.mp4',
  'astre': '/Videos/Video Astre (Apto Modelo).mp4',
  'filia': '/Videos/Video_proyecto_-_Filia_xbc3da.mp4',
  'amitie': '/Videos/Video_proyecto_-_Amitie_yyd81s.mp4',
  'lagun': '/Videos/Video_proyecto_-_Lagun_hcvxxb.mp4',
  'verona': '/Videos/Video_proyecto_-_Verona_u7febi.mp4',
  'siena': '/Videos/Video_proyecto_-_Siena_zwm741.mp4',
  'piamonte': '/Videos/Video_proyecto_-_Piamonte_ikfupf.mp4',
};
const heroVideo = videoMap[project.id];

const coordsMap: Record<string, [number, number]> = {
  'athas': [9.0137152, -79.5079926],
  'alai': [9.0015646, -79.5162092],
  'astre': [8.9823792, -79.5199793],
  'gaudi': [9.0072838, -79.5089367],
  'filia': [9.0780227, -79.4132632],
  'amitie': [9.0706808, -79.3996566],
  'lagun': [9.0715312, -79.4658814],
  'verona': [8.9247678, -79.7653817],
  'siena': [8.9248613, -79.7603834],
  'solaris': [8.9190748, -79.7484882],
  'piamonte': [8.9186541, -79.7499648],
  'provenza': [9.111219, -79.252625],
};
const [projectLat, projectLng] = coordsMap[project.id] || [9.0, -79.5];
const MAPBOX_TOKEN = import.meta.env.PUBLIC_MAPBOX_TOKEN || '';

const galleryLen = project.gallery.length;
const amenityImages = project.amenidades && project.amenidades.length > 0
  ? [
      project.amenidades[0],
      project.amenidades[Math.floor(project.amenidades.length / 3)],
      project.amenidades[Math.floor(project.amenidades.length * 2 / 3)]
    ]
  : [
      project.gallery[0],
      project.gallery[Math.floor(galleryLen / 3)],
      project.gallery[Math.floor(galleryLen * 2 / 3)]
    ];
---

<Layout title={`${project.name} | Haus Panama`} fixedHeader={false}>
  <HeaderNonSticky />
  <ChatWrapper />

  <main class="font-helvetica w-full bg-white">
    <!-- 1. HERO SECTION (rounded, padded like home hero) -->
    <section class="w-full px-5 lg:px-8 pt-0">
      <div class="relative w-full max-w-[1312px] mx-auto rounded-[24px] overflow-hidden">
        {heroVideo ? (
          <video 
            src={heroVideo}
            autoplay muted loop playsinline
            class="w-full h-[50vh] md:h-[55vh] lg:h-[65vh] xl:h-[70vh] object-cover"
          />
        ) : (
          <img 
            src={`${imageBasePath}/${project.coverImage}`} 
            alt={project.name}
            class="w-full h-[50vh] md:h-[55vh] lg:h-[65vh] xl:h-[70vh] object-cover"
            loading="eager"
          />
        )}
        <div class="absolute inset-0 bg-[#464648]/40 mix-blend-multiply"></div>
        
        <div class="absolute bottom-6 right-6 md:bottom-10 md:right-10 flex flex-col items-end gap-3">
          <img 
            src={`/Portadas/${project.logo2}`} 
            alt={project.name}
            class="w-[120px] sm:w-[160px] md:w-[200px] lg:w-[250px] object-contain drop-shadow-lg"
            loading="eager"
          />
          <BrochureDownloader
            client:load
            brochureFile={project.brochureFile}
            projectName={project.name}
            buttonText={project.buttonText}
            projectLocation={projectLocation}
            projectId={project.id}
            className="bg-[var(--primary)] text-white rounded-[8px] px-5 py-2.5 md:px-6 md:py-3 text-sm md:text-base font-medium transition-all duration-300 hover:brightness-110 hover:scale-[1.02]"
          />
        </div>
      </div>
    </section>

    <!-- 2. PROJECT INFO SECTION -->
    <section class="w-full px-5 lg:px-8 py-12 md:py-16 lg:py-20">
      <div class="max-w-[800px] mx-auto text-center">
        <span class="inline-block border border-[#3a3a3c] rounded-full px-5 py-1 text-sm text-[#3a3a3c] mb-4">
          PH {project.name}
        </span>
        
        <h1 class="text-[#3a3a3c] font-bold text-2xl sm:text-3xl md:text-4xl lg:text-[42px] leading-tight mb-6">
          {project.slogan}
        </h1>
        
        <p class="text-[#3a3a3c]/70 text-sm sm:text-base md:text-lg leading-relaxed mb-10 max-w-[700px] mx-auto">
          {project.description}
        </p>
        
        <div class="flex items-center justify-center gap-10 md:gap-14">
          <div class="flex items-center gap-3">
            <img src="/Icons/Recamara-01.svg" alt="Recámaras" class="w-10 h-10 md:w-12 md:h-12" loading="lazy" />
            <span class="text-[#3a3a3c] text-sm md:text-base font-medium">{project.bedrooms} rec.</span>
          </div>

          <div class="flex items-center gap-3">
            <img src="/Icons/Metrajes-01.svg" alt="Metraje" class="w-10 h-10 md:w-12 md:h-12" loading="lazy" />
            <span class="text-[#3a3a3c] text-sm md:text-base font-medium">desde {project.size}m²</span>
          </div>
        </div>
      </div>
    </section>

    <!-- 3. GALLERY CAROUSEL -->
    <section class="w-full pb-12 md:pb-16">
      <div class="w-full">
        <ImageCarousel client:visible images={project.gallery} projectId={project.id} projectLocation={projectLocation} />
      </div>
    </section>
    <!-- 4. AMENIDADES SECTION -->
    <section class="w-full px-5 lg:px-8 py-12 md:py-16 lg:py-20">
      <div class="max-w-[1100px] mx-auto">
        <div class="text-center mb-4">
          <span class="inline-block border border-[#3a3a3c] rounded-full px-5 py-1 text-sm text-[#3a3a3c]">
            amenidades
          </span>
        </div>
        
        <h2 class="text-[#3a3a3c] font-bold text-2xl sm:text-3xl md:text-4xl lg:text-[42px] leading-tight text-center mb-10 lg:mb-14">
          amenidades pensadas para el día a día
        </h2>
        
        <div class="flex flex-wrap justify-center gap-6 md:gap-10 lg:gap-14 mb-10 lg:mb-14">
          {project.features.slice(0, 6).map((feature) => (
            <div class="flex flex-col items-center gap-2 w-[80px] md:w-[100px]">
              <img 
                src={`/Icons/${feature.icon}`} 
                alt={feature.text}
                class="w-12 h-12 md:w-14 md:h-14"
                loading="lazy"
              />
              <span class="text-[#3a3a3c] text-xs md:text-sm text-center leading-tight">{feature.text}</span>
            </div>
          ))}
        </div>
        
        <div class="grid grid-cols-1 sm:grid-cols-3 gap-4 lg:gap-6">
          {amenityImages.map((img) => (
            <div class="rounded-[10px] overflow-hidden aspect-[4/3]">
              <img
                src={`${imageBasePath}/${img}`}
                alt="Amenidad del proyecto"
                class="w-full h-full object-cover"
                loading="lazy"
              />
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- 5. MAP + CONTACT FORM SECTION -->
    <section class="w-full px-5 lg:px-8 py-12 md:py-16 lg:py-20 bg-white">
      <div class="max-w-[1312px] mx-auto">
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-8 lg:gap-12 items-stretch">
          <div class="flex flex-col gap-3">
            <div class="rounded-[10px] overflow-hidden min-h-[400px] flex-1">
              <MapboxMap client:visible lat={projectLat} lng={projectLng} projectName={project.name} mapsUrl={project.mapsUrl} accessToken={MAPBOX_TOKEN} />
            </div>
            <a
              href={project.mapsUrl}
              target="_blank"
              rel="noopener noreferrer"
              class="bg-[var(--primary)] text-white text-sm font-medium px-4 py-2.5 rounded-[8px] flex items-center justify-center gap-2 hover:brightness-110 transition-all w-fit"
            >
              <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
                <path stroke-linecap="round" stroke-linejoin="round" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
              </svg>
              ver en Google Maps
            </a>
          </div>
          
          <div class="bg-white rounded-[10px] flex flex-col">
            <style is:inline>
              .pipedriveWebForms { width: 100%; display: flex; flex-direction: column; align-items: center; flex: 1; }
              .pipedrive-form-iframe { width: 100% !important; height: 100% !important; min-height: 600px !important; overflow: hidden !important; border: none !important; border-radius: 0 0 10px 10px !important; display: block !important; flex-grow: 1 !important; }
              .pipedrive-form-container { width: 100%; flex: 1; display: flex; flex-direction: column; align-items: center; overflow: visible; }
              .ppf__button { margin-bottom: 0 !important; }
              .ppf__form > div:last-child { margin-bottom: 0 !important; }
              @media (max-width: 639px) { .pipedrive-form-container { padding: 0; } }
              @media (min-width: 1024px) { .ppf__form { padding: 0 !important; margin: 0 !important; } .ppf__field { margin-bottom: 12px !important; } }
            </style>
            
            <div class="px-6 md:px-8 pt-6 md:pt-8">
              <h2 class="text-[var(--primary)] text-xl md:text-2xl lg:text-3xl font-bold text-center italic mb-2">
                ¡Gracias por tu interés en nuestro proyecto!
              </h2>
              <p class="text-center text-sm md:text-base text-[#3a3a3c]/70 mb-6">
                Por favor brindanos tus datos para poder contactarte y enviarte información más detallada del proyecto.
              </p>
            </div>
            
            <div class="pipedrive-form-container">
              <div
                class="pipedriveWebForms w-full"
                data-pd-webforms={project.pipedriveFormUrl}
                id={`form-${project.id}`}
              >
                <script define:vars={{ formId: project.id }}>
                  window.addEventListener('message', function(event) {
                    if (event.data && typeof event.data === 'object' && event.data.type === 'pipedrive-form-height') {
                      const iframeSelector = `iframe[name="hauspanama-${formId}"]`;
                      const iframe = document.querySelector(iframeSelector);
                      if (iframe && event.data.height && iframe instanceof HTMLElement) {
                        iframe.style.height = `${event.data.height}px`;
                      }
                    }
                  });

                  function adjustIframeHeight() {
                    const iframeSelector = `iframe[name="hauspanama-${formId}"]`;
                    const iframe = document.querySelector(iframeSelector);
                    if (iframe && iframe.contentWindow) {
                      try {
                        const height = iframe.contentWindow.document.body.scrollHeight;
                        if (height > 400) { iframe.style.height = `${height}px`; }
                      } catch (e) {
                        console.log('CORS policy prevents iframe height reading');
                      }
                    }
                  }

                  const script = document.createElement('script');
                  script.src = 'https://webforms.pipedrive.com/f/loader';
                  script.async = true;
                  document.body.appendChild(script);
                  setTimeout(adjustIframeHeight, 2000);
                  setTimeout(adjustIframeHeight, 4000);
                </script>

                <iframe
                  src={`${project.pipedriveFormUrl}?embedded=1&uuid=form-${project.id}`}
                  name={`hauspanama-${project.id}`}
                  title="Web Forms"
                  class="pipedrive-form-iframe"
                  scrolling="no"
                  allowtransparency="true"
                ></iframe>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>
  </main>

  <SocialFooter />
</Layout>
