---
import LocalImage from '../LocalImage.astro';

// Obtener la ruta actual para resaltar el ítem activo
const currentPath = Astro.url.pathname;

// Detectar la página activa normalizando las rutas
const isHomePage = currentPath === '/' || currentPath === '';
const isAboutPage = currentPath.startsWith('/about') || currentPath.startsWith('/sobre-nosotros') || currentPath.includes('nosotros');
const isContactPage = currentPath.includes('contacto') || currentPath.includes('contact');
const isProjectsPage = currentPath === '/apartamentos' || currentPath === '/apartamentos/' ||
                     currentPath === '/casas' || currentPath === '/casas/' ||
                     currentPath.includes('/centro') || 
                     currentPath.includes('/este') || 
                     currentPath.includes('/oeste') ||
                     currentPath.includes('/athas') ||

                     currentPath.includes('/alai') ||
                     currentPath.includes('/astre') ||
                     currentPath.includes('/amitie') ||
                     currentPath.includes('/lagun') ||
                     currentPath.includes('/filia') ||
                     currentPath.includes('/casas-este') ||
                     currentPath.includes('/verona') ||
                     currentPath.includes('/piamonte') ||
                     currentPath.includes('/siena') ||
                     currentPath.includes('/provenza') ||
                     currentPath.includes('/solaris') ||
                     currentPath.includes('/proyecto') ||
                     currentPath.includes('/apartamentos-') ||
                     currentPath.includes('/casas-');
---

<!-- Mobile menu overlay -->
<div 
  id="mobile-menu" 
  class="fixed top-0 left-0 w-full h-full z-[9999] hidden bg-white transition-all duration-300 ease-in-out transform opacity-0 -translate-y-4"
  style="display:none;"
  aria-hidden="true"
  role="dialog"
  aria-modal="true"
  aria-label="Menú de navegación móvil"
>
  <!-- Mobile menu header -->
  <div class="flex items-center px-5 py-2.5 w-full">
    <div class="bg-[#f7f7f7] flex items-center justify-between h-[60px] px-5 rounded-[50px] w-full">
      <a href="/">
        <LocalImage 
          src="Logos/logohaus_usiwqr.svg" 
          alt="Haus Panama Logo" 
          className="h-[28px]" 
        />
      </a>
      <!-- Close button (dash icon matching Figma) -->
      <button 
        id="mobile-menu-close" 
        class="w-[40px] h-[40px] flex items-center justify-center"
        aria-label="Cerrar menú de navegación"
      >
        <svg xmlns="http://www.w3.org/2000/svg" class="w-7 h-7 text-[#3a3a3c]" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
          <path stroke-linecap="round" stroke-linejoin="round" d="M5 12h14" />
        </svg>
      </button>
    </div>
  </div>

  <!-- Nav items centered -->
  <nav class="flex-1 flex flex-col items-center justify-center h-[calc(100%-80px)]" aria-label="Navegación principal">
    <ul class="flex flex-col items-center gap-8">
      <li>
        <a 
          href="/" 
          class={`text-[20px] font-medium transition-all duration-300 hover:text-[var(--primary)] ${isHomePage ? 'text-[var(--primary)] font-bold' : 'text-[#3a3a3c]'}`}
        >
          inicio
        </a>
      </li>
      <li>
        <a 
          href="/#sobre-nosotros" 
          class={`text-[20px] font-medium transition-all duration-300 hover:text-[var(--primary)] ${isAboutPage ? 'text-[var(--primary)] font-bold' : 'text-[#3a3a3c]'}`}
        >
          quienes somos
        </a>
      </li>
      <li class="w-full flex flex-col items-center">
        <!-- Botón principal proyectos -->
        <button
          id="mobile-projects-toggle"
          class={`flex items-center gap-2 text-[20px] font-medium transition-all duration-300 hover:text-[var(--primary)] ${isProjectsPage ? 'text-[var(--primary)] font-bold' : 'text-[#3a3a3c]'}`}
        >
          <span>proyectos</span>
          <svg id="mobile-projects-arrow" class="transform transition-transform duration-200" xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
            <path d="m6 9 6 6 6-6"/>
          </svg>
        </button>

        <!-- Submenú por zonas -->
        <div id="mobile-projects-menu" class="mt-4 w-full max-w-[220px] text-center" style="display:none; flex-direction:column; gap:12px;">

          <!-- Centro -->
          <div>
            <button class="mobile-zone-toggle w-full flex items-center justify-center gap-2 text-[20px] font-bold text-[#3a3a3c] hover:text-[var(--primary)] transition-colors" data-zone="mobile-centro">
              <span>Centro</span>
              <svg class="mobile-zone-arrow transform transition-transform duration-200" xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                <path d="m6 9 6 6 6-6"/>
              </svg>
            </button>
            <div class="mobile-zone-menu mt-2" style="display:none; flex-direction:column; gap:8px;" data-zone="mobile-centro">
              <a href="/athas" class="text-[20px] font-medium text-gray-500 hover:text-[var(--primary)] transition-colors py-1">áthas</a>
              <a href="/alai" class="text-[20px] font-medium text-gray-500 hover:text-[var(--primary)] transition-colors py-1">alai</a>
              <a href="https://astrepanama.com" target="_blank" rel="noopener noreferrer" class="text-[20px] font-medium text-gray-500 hover:text-[var(--primary)] transition-colors py-1">astre ↗</a>
            </div>
          </div>

          <div class="border-t border-gray-200"></div>

          <!-- Este -->
          <div>
            <button class="mobile-zone-toggle w-full flex items-center justify-center gap-2 text-[20px] font-bold text-[#3a3a3c] hover:text-[var(--primary)] transition-colors" data-zone="mobile-este">
              <span>Este</span>
              <svg class="mobile-zone-arrow transform transition-transform duration-200" xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                <path d="m6 9 6 6 6-6"/>
              </svg>
            </button>
            <div class="mobile-zone-menu mt-2" style="display:none; flex-direction:column; gap:8px;" data-zone="mobile-este">
              <a href="/amitie" class="text-[20px] font-medium text-gray-500 hover:text-[var(--primary)] transition-colors py-1">amitié</a>
              <a href="/lagun" class="text-[20px] font-medium text-gray-500 hover:text-[var(--primary)] transition-colors py-1">lagun</a>
              <a href="/filia" class="text-[20px] font-medium text-gray-500 hover:text-[var(--primary)] transition-colors py-1">filia</a>
              <a href="/provenza" class="text-[20px] font-medium text-gray-500 hover:text-[var(--primary)] transition-colors py-1">provenza</a>
            </div>
          </div>

          <div class="border-t border-gray-200"></div>

          <!-- Oeste -->
          <div>
            <button class="mobile-zone-toggle w-full flex items-center justify-center gap-2 text-[20px] font-bold text-[#3a3a3c] hover:text-[var(--primary)] transition-colors" data-zone="mobile-oeste">
              <span>Oeste</span>
              <svg class="mobile-zone-arrow transform transition-transform duration-200" xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                <path d="m6 9 6 6 6-6"/>
              </svg>
            </button>
            <div class="mobile-zone-menu mt-2" style="display:none; flex-direction:column; gap:8px;" data-zone="mobile-oeste">
              <a href="/solaris" class="text-[20px] font-medium text-gray-500 hover:text-[var(--primary)] transition-colors py-1">solaris</a>
              <a href="/verona" class="text-[20px] font-medium text-gray-500 hover:text-[var(--primary)] transition-colors py-1">verona</a>
              <a href="/piamonte" class="text-[20px] font-medium text-gray-500 hover:text-[var(--primary)] transition-colors py-1">piamonte</a>
              <a href="/siena" class="text-[20px] font-medium text-gray-500 hover:text-[var(--primary)] transition-colors py-1">siena</a>
            </div>
          </div>

        </div>
      </li>
      <li>
        <a 
          href="/contacto" 
          class={`text-[20px] font-medium transition-all duration-300 hover:text-[var(--primary)] ${isContactPage ? 'text-[var(--primary)] font-bold' : 'text-[#3a3a3c]'}`}
        >
          contacto
        </a>
      </li>
    </ul>
  </nav>
</div>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const projectsToggle = document.getElementById('mobile-projects-toggle');
    const projectsMenu = document.getElementById('mobile-projects-menu');
    const projectsArrow = document.getElementById('mobile-projects-arrow');

    if (!projectsToggle || !projectsMenu || !projectsArrow) return;

    // Alternar menú principal de proyectos
    projectsToggle.addEventListener('click', () => {
      const isHidden = projectsMenu.style.display === 'none' || projectsMenu.style.display === '';

      if (isHidden) {
        projectsMenu.style.display = 'flex';
        projectsArrow.classList.add('rotate-180');
      } else {
        projectsMenu.style.display = 'none';
        projectsArrow.classList.remove('rotate-180');
        // Cerrar todos los submenús de zona
        document.querySelectorAll('.mobile-zone-menu').forEach((menu) => {
          (menu as HTMLElement).style.display = 'none';
        });
        document.querySelectorAll('.mobile-zone-arrow').forEach((arrow) => {
          arrow.classList.remove('rotate-180');
        });
      }
    });

    // Alternar submenú por zona
    document.querySelectorAll('.mobile-zone-toggle').forEach((toggle) => {
      toggle.addEventListener('click', (e) => {
        e.stopPropagation();
        const zone = (toggle as HTMLElement).dataset.zone;
        const zoneMenu = document.querySelector(`.mobile-zone-menu[data-zone="${zone}"]`) as HTMLElement | null;
        const zoneArrow = toggle.querySelector('.mobile-zone-arrow');

        if (!zoneMenu || !zoneArrow) return;

        const isHidden = zoneMenu.style.display === 'none' || zoneMenu.style.display === '';

        // Cerrar todos primero
        document.querySelectorAll('.mobile-zone-menu').forEach((menu) => {
          (menu as HTMLElement).style.display = 'none';
        });
        document.querySelectorAll('.mobile-zone-arrow').forEach((arrow) => {
          arrow.classList.remove('rotate-180');
        });

        // Abrir el seleccionado si estaba cerrado
        if (isHidden) {
          zoneMenu.style.display = 'flex';
          zoneArrow.classList.add('rotate-180');
        }
      });
    });
  });
</script>
