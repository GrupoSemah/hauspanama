---
export interface Props {
  formAction: string;
  formId: string;
}

const { formAction, formId } = Astro.props;

// Site key pública de Cloudflare Turnstile — debe estar en el .env como PUBLIC_TURNSTILE_SITE_KEY
const turnstileSiteKey = import.meta.env.PUBLIC_TURNSTILE_SITE_KEY as string | undefined;

// Atributos personalizados de Zoho que no existen en el tipo HTMLInputElement de TypeScript.
// validation.js los lee vía getAttribute(), por lo que deben estar en el DOM como atributos.
const zohoTextAttrs = { checktype: "c1", fieldType: "1" } as Record<string, string>;
const zohoEmailAttrs = { checktype: "c5", fieldType: "9" } as Record<string, string>;
const zohoSelectAttrs = { checktype: "c1" } as Record<string, string>;
---

<!-- Cabecera del formulario: mismo estilo que el bloque de Pipedrive -->
<div class="px-6 md:px-8 pt-6 md:pt-8">
  <h2 class="text-[var(--primary)] text-xl md:text-2xl lg:text-3xl font-bold text-center italic mb-2">
    ¡Gracias por tu interés en nuestro proyecto!
  </h2>
  <p class="text-center text-sm md:text-base text-[#3a3a3c]/70 mb-6">
    Por favor brindanos tus datos para poder contactarte y enviarte información más detallada del proyecto.
  </p>
</div>

<!-- Formulario Zoho — action/method se conservan como fallback no-JS; el submit real lo maneja JS via fetch -->
<form
  id="form"
  name="form"
  action={formAction}
  method="POST"
  enctype="multipart/form-data"
  accept-charset="UTF-8"
  class="w-full px-6 md:px-8 pb-8 flex flex-col gap-5"
>
  <!-- Campos ocultos requeridos por Zoho Forms -->
  <input type="hidden" name="zf_referrer_name" value="" />
  <input type="hidden" name="zf_redirect_url" value="https://hauspanama.com/gracias" />
  <input type="hidden" name="zc_gad" value="" />
  <input type="hidden" name="utm_source" value="" />
  <input type="hidden" name="utm_medium" value="" />
  <input type="hidden" name="utm_campaign" value="" />
  <input type="hidden" name="utm_term" value="" />
  <input type="hidden" name="utm_content" value="" />

  <!-- Honeypot anti-bot: oculto fuera de pantalla, invisible para humanos, visible para bots -->
  <div
    aria-hidden="true"
    style="position:absolute; left:-9999px; top:auto; width:1px; height:1px; overflow:hidden;"
  >
    <label for={`hp_website-${formId}`} aria-hidden="true">Website</label>
    <input
      type="text"
      id={`hp_website-${formId}`}
      name="hp_website"
      tabindex="-1"
      autocomplete="off"
      aria-hidden="true"
      value=""
    />
  </div>

  <!-- Campo: Nombre completo -->
  <div class="flex flex-col gap-1.5">
    <label
      for={`SingleLine-${formId}`}
      class="text-sm font-medium text-[#3a3a3c]"
    >
      Nombre completo <span class="text-red-500">*</span>
    </label>
    <input
      id={`SingleLine-${formId}`}
      type="text"
      name="SingleLine"
      value=""
      maxlength="255"
      placeholder=""
      {...zohoTextAttrs}
      class="w-full border border-gray-300 rounded-[8px] px-4 py-2.5 text-sm text-[#3a3a3c] placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-[var(--primary)] focus:border-transparent transition-all"
    />
    <p id="SingleLine_error" class="zf-errorMessage text-xs text-red-500" style="display:none;">
      Invalid value
    </p>
  </div>

  <!-- Campo: Teléfono / WhatsApp -->
  <div class="flex flex-col gap-1.5">
    <label
      for={`SingleLine1-${formId}`}
      class="text-sm font-medium text-[#3a3a3c]"
    >
      Número de teléfono / WhatsApp <span class="text-red-500">*</span>
    </label>
    <input
      id={`SingleLine1-${formId}`}
      type="text"
      name="SingleLine1"
      value=""
      maxlength="255"
      placeholder=""
      {...zohoTextAttrs}
      class="w-full border border-gray-300 rounded-[8px] px-4 py-2.5 text-sm text-[#3a3a3c] placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-[var(--primary)] focus:border-transparent transition-all"
    />
    <p id="SingleLine1_error" class="zf-errorMessage text-xs text-red-500" style="display:none;">
      Invalid value
    </p>
  </div>

  <!-- Campo: Correo Electrónico -->
  <div class="flex flex-col gap-1.5">
    <label
      for={`Email-${formId}`}
      class="text-sm font-medium text-[#3a3a3c]"
    >
      Correo Electrónico <span class="text-red-500">*</span>
    </label>
    <input
      id={`Email-${formId}`}
      type="text"
      name="Email"
      value=""
      maxlength="255"
      placeholder=""
      {...zohoEmailAttrs}
      class="w-full border border-gray-300 rounded-[8px] px-4 py-2.5 text-sm text-[#3a3a3c] placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-[var(--primary)] focus:border-transparent transition-all"
    />
    <p id="Email_error" class="zf-errorMessage text-xs text-red-500" style="display:none;">
      Invalid value
    </p>
  </div>

  <!-- Campo: Ingreso familiar -->
  <div class="flex flex-col gap-1.5">
    <label
      for={`Dropdown-${formId}`}
      class="text-sm font-medium text-[#3a3a3c]"
    >
      Ingreso familiar <span class="text-red-500">*</span>
    </label>
    <select
      id={`Dropdown-${formId}`}
      class="zf-form-sBox w-full border border-gray-300 rounded-[8px] px-4 py-2.5 text-sm text-[#3a3a3c] bg-white focus:outline-none focus:ring-2 focus:ring-[var(--primary)] focus:border-transparent transition-all appearance-none cursor-pointer"
      name="Dropdown"
      {...zohoSelectAttrs}
    >
      <option value="-Select-">-Select-</option>
      <option value="Menos de $800">Menos de $800</option>
      <option value="$801 a $1,000">$801 a $1,000</option>
      <option value="$1,001 a $1,500">$1,001 a $1,500</option>
      <option value="$1,501 a $2,000">$1,501 a $2,000</option>
      <option value="$2,001 a $2,500">$2,001 a $2,500</option>
      <option value="$2,501 a $3,000">$2,501 a $3,000</option>
      <option value="Mayor a $3,000">Mayor a $3,000</option>
    </select>
    <p id="Dropdown_error" class="zf-errorMessage text-xs text-red-500" style="display:none;">
      Invalid value
    </p>
  </div>

  <!-- Widget de Cloudflare Turnstile — solo se renderiza si la site key está definida -->
  {turnstileSiteKey && (
    <div class="cf-turnstile" data-sitekey={turnstileSiteKey} data-theme="light"></div>
  )}

  <!-- Mensaje de error genérico del submit (oculto por defecto) -->
  <p
    id={`form-error-${formId}`}
    class="text-xs text-red-500 text-center hidden"
    aria-live="polite"
  ></p>

  <!-- Botón de envío -->
  <button
    id={`submit-btn-${formId}`}
    type="submit"
    class="w-full bg-[var(--primary)] text-white font-semibold text-sm rounded-[8px] px-6 py-3 hover:brightness-110 active:scale-[0.98] transition-all mt-1 cursor-pointer disabled:opacity-60 disabled:cursor-not-allowed"
  >
    Enviar
  </button>
</form>

<!-- Script de Cloudflare Turnstile — cargado async/defer para no bloquear el render -->
<script is:inline src="https://challenges.cloudflare.com/turnstile/v0/api.js" async defer></script>

<!-- Guard anti-bot + flujo de submit via fetch hacia /api/zoho-lead -->
<script is:inline define:vars={{ formId, formAction }}>
  // Registra el momento de carga por instancia para evitar colisiones entre múltiples formularios
  window.__hpFormLoad = window.__hpFormLoad || {};
  window.__hpFormLoad[formId] = Date.now();

  (function () {
    var form = document.getElementById('form');
    if (!form) { return; }

    form.addEventListener('submit', function (e) {
      // Siempre prevenir la navegación nativa — el submit lo maneja fetch
      e.preventDefault();

      var errorEl = document.getElementById('form-error-' + formId);
      var submitBtn = document.getElementById('submit-btn-' + formId);

      // Oculta cualquier mensaje de error previo
      if (errorEl) {
        errorEl.textContent = '';
        errorEl.classList.add('hidden');
      }

      // --- 1. Check honeypot ---
      var hp = document.getElementById('hp_website-' + formId);
      if (hp && hp.value.trim() !== '') {
        // Bot detectado — falla en silencio
        return;
      }

      // --- 2. Check timing (< 3 segundos → bot) ---
      if (Date.now() - window.__hpFormLoad[formId] < 3000) {
        // Submit demasiado rápido — falla en silencio
        return;
      }

      // --- 3. Validación de campos Zoho ---
      if (typeof window.zf_ValidateAndSubmit === 'function') {
        if (!window.zf_ValidateAndSubmit()) {
          // zf_ValidateAndSubmit ya muestra los errores de campo en el DOM
          return;
        }
      }

      // --- 4. Token de Turnstile ---
      var turnstileInput = form.querySelector('[name="cf-turnstile-response"]');
      var turnstileToken = turnstileInput ? turnstileInput.value : '';

      // Si hay widget activo (hay un .cf-turnstile en el form) y el token está vacío → bloquear
      var hasTurnstileWidget = !!form.querySelector('.cf-turnstile');
      if (hasTurnstileWidget && !turnstileToken) {
        if (errorEl) {
          errorEl.textContent = 'Por favor completa la verificación de seguridad.';
          errorEl.classList.remove('hidden');
        }
        return;
      }

      // --- 5. Construir payload con el contrato exacto del endpoint ---
      var payload = {
        projectId: formId,
        name:    (document.getElementById('SingleLine-' + formId) || {}).value || '',
        phone:   (document.getElementById('SingleLine1-' + formId) || {}).value || '',
        email:   (document.getElementById('Email-' + formId) || {}).value || '',
        income:  (document.getElementById('Dropdown-' + formId) || {}).value || '',
        honeypot: hp ? hp.value : '',
        turnstileToken: turnstileToken,
        utm: {
          utm_source:   (form.querySelector('[name="utm_source"]') || {}).value || '',
          utm_medium:   (form.querySelector('[name="utm_medium"]') || {}).value || '',
          utm_campaign: (form.querySelector('[name="utm_campaign"]') || {}).value || '',
          utm_term:     (form.querySelector('[name="utm_term"]') || {}).value || '',
          utm_content:  (form.querySelector('[name="utm_content"]') || {}).value || '',
        },
        referrer: (form.querySelector('[name="zf_referrer_name"]') || {}).value || '',
      };

      // --- 6. Deshabilitar botón para evitar doble submit ---
      if (submitBtn) {
        submitBtn.disabled = true;
        submitBtn.textContent = 'Enviando…';
      }

      // --- 7. Enviar al endpoint propio ---
      fetch('/api/zoho-lead', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(payload),
      })
        .then(function (res) {
          if (res.status === 429) {
            return res.json().then(function () {
              throw { status: 429 };
            }).catch(function () {
              throw { status: 429 };
            });
          }
          return res.json().then(function (data) {
            return { ok: res.ok, data: data };
          });
        })
        .then(function (result) {
          if (result.ok && result.data && result.data.success) {
            window.location.href = '/gracias';
          } else {
            throw { status: 0 };
          }
        })
        .catch(function (err) {
          // Reactivar botón en cualquier error
          if (submitBtn) {
            submitBtn.disabled = false;
            submitBtn.textContent = 'Enviar';
          }
          if (errorEl) {
            if (err && err.status === 429) {
              errorEl.textContent = 'Demasiados intentos, espera un momento.';
            } else {
              errorEl.textContent = 'Hubo un problema al enviar. Intenta de nuevo.';
            }
            errorEl.classList.remove('hidden');
          }
        });
    });
  })();
</script>

<!-- Carga del validador de Zoho como script externo (no bundleado por Astro) -->
<script is:inline src="/zoho/validation.js"></script>

<!-- Arrays de configuración requeridos por validation.js -->
<script is:inline>
  var dateAndMonthRegexFormateArray = zf_SetDateAndMonthRegexBasedOnDateFormate('dd-MMM-yyyy');
  var zf_DateRegex = new RegExp(dateAndMonthRegexFormateArray[0]);
  var zf_MonthYearRegex = new RegExp(dateAndMonthRegexFormateArray[1]);
  var zf_MandArray = ["SingleLine", "SingleLine1", "Email", "Dropdown"];
  var zf_FieldArray = ["SingleLine", "SingleLine1", "Email", "Dropdown"];
  var isSalesIQIntegrationEnabled = false;
  var salesIQFieldsArray = [];
</script>

<!-- Captura UTM avanzada de Zoho (ZFAdvLead) — llena los hidden utm_* del form -->
<script is:inline>
  var ZFAdvLead = function() {};
  ZFAdvLead.prototype = {
    utmPNameArr: ["utm_source", "utm_medium", "utm_campaign", "utm_term", "utm_content"],

    zfautm_ini: function() {
      for (var i = 0; i < this.utmPNameArr.length; i++) {
        var zfutm_pVal = this.zfautm_gP(this.utmPNameArr[i]);
        if (zfutm_pVal) {
          this.zfautm_sC(this.utmPNameArr[i], zfutm_pVal);
        }
      }
    },

    zfautm_gP: function(paramName) {
      var pQuery = window.location.search;
      var zfutm_pRes = "";
      if (pQuery && pQuery.length > 0) {
        pQuery = pQuery.substring(1);
        var pParams = pQuery.split("&");
        for (var i = 0; i < pParams.length; i++) {
          var pPair = pParams[i].split("=");
          if (decodeURIComponent(pPair[0]) === paramName) {
            if (pPair.length > 1) {
              zfutm_pRes = decodeURIComponent(pPair[1]);
            }
            break;
          }
        }
      }
      if (!zfutm_pRes) {
        zfutm_pRes = this.zfautm_gC(paramName);
      }
      return zfutm_pRes;
    },

    zfautm_gC: function(cookieName) {
      var zfutm_cookieArr = document.cookie.split(";");
      for (var i = 0; i < zfutm_cookieArr.length; i++) {
        var zfutm_cPair = zfutm_cookieArr[i].split("=");
        var zfutm_cName = zfutm_cPair[0].replace(/^\s+|\s+$/g, "");
        if (zfutm_cName === cookieName) {
          return decodeURIComponent(zfutm_cPair[1]);
        }
      }
      return "";
    },

    zfautm_sC: function(cookieName, cookieVal) {
      var zfutm_exp = new Date();
      zfutm_exp.setDate(zfutm_exp.getDate() + 30);
      document.cookie = cookieName + "=" + encodeURIComponent(cookieVal) + "; expires=" + zfutm_exp.toUTCString() + "; path=/";
    },

    zfautm_bscPCap: function() {
      var zfutm_src = document.referrer;
      var zfutm_searchEngines = ["google", "yahoo", "bing", "ask", "aol", "duckduckgo"];
      if (zfutm_src) {
        for (var i = 0; i < zfutm_searchEngines.length; i++) {
          if (zfutm_src.indexOf(zfutm_searchEngines[i]) !== -1) {
            return "organic";
          }
        }
        return "referral";
      }
      return "direct";
    },

    zfautm_calcTrafSrc: function() {
      var zfutm_src = this.zfautm_gP("utm_source");
      if (!zfutm_src) {
        var zfutm_trafSrc = this.zfautm_bscPCap();
        if (zfutm_trafSrc !== "direct") {
          this.zfautm_sC("utm_source", document.referrer);
          this.zfautm_sC("utm_medium", zfutm_trafSrc);
        }
      }
    },

    zfautm_DHtmlSprt: function() {
      var zfutm_form = document.forms["form"];
      if (!zfutm_form) { return; }
      for (var i = 0; i < this.utmPNameArr.length; i++) {
        var zfutm_fldName = this.utmPNameArr[i];
        var zfutm_fldVal = this.zfautm_gP(zfutm_fldName);
        if (zfutm_fldVal && zfutm_form[zfutm_fldName]) {
          zfutm_form[zfutm_fldName].value = zfutm_fldVal;
        }
      }
    }
  };

  var zfutm_zfAdvLead = new ZFAdvLead();
  zfautm_ini = function() {
    zfutm_zfAdvLead.zfautm_calcTrafSrc();
    zfutm_zfAdvLead.zfautm_ini();
  };
  zfautm_ini();

  window.addEventListener("load", function() {
    zfutm_zfAdvLead.zfautm_DHtmlSprt();
  });
</script>
