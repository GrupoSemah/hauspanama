---
---

<section id="proyectos" class="w-full px-5 lg:px-8 py-12 md:py-16 lg:py-20">
  <div class="max-w-[1312px] mx-auto">
    <!-- Section header -->
    <div class="flex flex-col items-center gap-3 mb-10 lg:mb-14">
      <span class="inline-block border border-[#3a3a3c] rounded-full px-5 py-1 text-sm text-[#3a3a3c]">proyectos</span>
      <h2 class="text-[#3a3a3c] font-bold text-xl sm:text-2xl md:text-3xl lg:text-4xl xl:text-[48px] text-center leading-tight max-w-[627px]">
        proyectos pensados para cada forma de vivir
      </h2>
    </div>
    
    <!-- Category cards -->
    <div class="flex flex-col gap-10 lg:gap-[53px]">
      <!-- Apartamentos card -->
      <div class="bg-[#f7f7f7] rounded-[10px] p-4 lg:p-[21px]">
        <div class="flex flex-col lg:flex-row items-stretch gap-0 rounded-[10px] overflow-hidden">
          <!-- Content -->
          <div class="flex flex-col gap-3 px-5 py-6 lg:px-[50px] lg:py-[20px] justify-center lg:w-1/2 order-2 lg:order-1">
            <h3 class="text-black font-bold text-2xl sm:text-3xl lg:text-4xl xl:text-[48px]">apartamentos</h3>
            <p class="text-black text-sm sm:text-base lg:text-lg xl:text-[20px] leading-relaxed lg:leading-[1.5]">
              proyectos residenciales desde $95,000 hasta $450,000 en zonas estratégicas pensados para una vida urbana práctica y bien conectada.
            </p>
            <a href="/apartamentos" class="bg-[var(--primary)] text-white font-medium text-base sm:text-lg lg:text-[21px] px-8 lg:px-10 py-3.5 lg:py-4 rounded-[9px] text-center transition-all duration-300 hover:brightness-110 hover:scale-[1.02] mt-2">
              ver proyectos
            </a>
          </div>
          <!-- Image -->
          <div class="lg:w-1/2 h-[250px] sm:h-[278px] lg:h-[278px] order-1 lg:order-2 rounded-[9px] overflow-hidden">
            <img 
              src="/Backgrounds/categorias portada aptos-02.webp"
              alt="Apartamentos en Panamá" 
              class="w-full h-full object-cover"
              loading="lazy"
            />
          </div>
        </div>
      </div>
      
      <!-- Casas card -->
      <div class="bg-[#f7f7f7] rounded-[10px] p-4 lg:p-[21px]">
        <div class="flex flex-col lg:flex-row items-stretch gap-0 rounded-[10px] overflow-hidden">
          <!-- Image -->
          <div class="lg:w-1/2 h-[250px] sm:h-[278px] lg:h-[278px] rounded-[9px] overflow-hidden">
            <img 
              src="/Backgrounds/categorias portada casas-01.webp"
              alt="Casas en Panamá" 
              class="w-full h-full object-cover"
              loading="lazy"
            />
          </div>
          <!-- Content -->
          <div class="flex flex-col gap-3 px-5 py-6 lg:px-[50px] lg:py-[20px] justify-center lg:w-1/2">
            <h3 class="text-black font-bold text-2xl sm:text-3xl lg:text-4xl xl:text-[48px]">casas</h3>
            <p class="text-black text-sm sm:text-base lg:text-lg xl:text-[20px] leading-relaxed lg:leading-[1.5]">
              comunidades residenciales desde $85,000 hasta $160,000 en sectores clave de Panamá, diseñadas para el ritmo de la vida familiar.
            </p>
            <a href="/casas" class="bg-[var(--primary)] text-white font-medium text-base sm:text-lg lg:text-[21px] px-8 lg:px-10 py-3.5 lg:py-4 rounded-[9px] text-center transition-all duration-300 hover:brightness-110 hover:scale-[1.02] mt-2">
              ver proyectos
            </a>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
