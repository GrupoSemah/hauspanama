---
import LocalImage from '../LocalImage.astro';
import DesktopNav from '../navigation/DesktopNav.astro';
import MobileNav from '../navigation/MobileNav.astro';
---

<header class="relative top-0 left-0 right-0 z-50 w-full bg-white font-helvetica">
  <!-- Desktop header: pill-shaped -->
  <div class="hidden xl:flex justify-center items-center px-16 py-[30px] w-full max-w-[1440px] mx-auto">
    <div class="bg-[#f7f7f7] flex items-center justify-between gap-[81px] h-[76px] px-[62px] py-4 rounded-[55px] w-full max-w-[1320px]">
      <a href="/" class="flex-shrink-0">
        <LocalImage 
          src="Logos/logohaus_usiwqr.svg" 
          alt="Haus Panama Logo" 
          className="h-[35px]" 
        />
      </a>
      <DesktopNav />
      <a href="/contacto" class="bg-[var(--primary)] text-white font-bold text-[16px] px-[25px] py-[15px] rounded-[4px] whitespace-nowrap transition-all duration-300 hover:brightness-110 hover:scale-[1.02] flex-shrink-0">
        contáctanos
      </a>
    </div>
  </div>

  <!-- Mobile header: pill-shaped -->
  <div class="xl:hidden flex items-center px-5 py-2.5 w-full">
    <div class="bg-[#f7f7f7] flex items-center justify-between h-[60px] px-5 rounded-[50px] w-full">
      <a href="/">
        <LocalImage 
          src="Logos/logohaus_usiwqr.svg" 
          alt="Haus Panama Logo" 
          className="h-[28px]" 
        />
      </a>
      <button id="mobile-menu-toggle" class="w-[40px] h-[40px] flex items-center justify-center" aria-label="Abrir menú de navegación">
        <svg xmlns="http://www.w3.org/2000/svg" class="w-7 h-7 text-[#3a3a3c]" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
          <line x1="4" y1="6" x2="20" y2="6" stroke-linecap="round" />
          <line x1="6" y1="12" x2="18" y2="12" stroke-linecap="round" />
          <line x1="4" y1="18" x2="20" y2="18" stroke-linecap="round" />
        </svg>
      </button>
    </div>
  </div>
</header>

<!-- MobileNav OUTSIDE header so fixed overlay works correctly -->
<MobileNav />

<script>
  import { initMobileMenu } from '../navigation/mobileMenuHandler.js';
  document.addEventListener('DOMContentLoaded', initMobileMenu);
</script>
