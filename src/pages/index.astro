---
import Layout from '../layouts/Layout.astro';
import HeaderNonSticky from '../components/home/HeaderNonSticky.astro';
import SocialFooter from '../components/home/SocialFooter.astro';
import ChatWrapper from '../components/ChatWrapper.astro';
import AboutSection from '../components/home/AboutSection.astro';
import LocalImage from '../components/LocalImage.astro';

const mainCards = [
  {
    id: 'oeste',
    title: 'casas en',
    title2: 'panamá oeste',
    subtitle: 'desde $82k',
    link: '/casas-y-aptos-oeste',
    imagePath: 'Proyectos/Oeste/Siena/Fotos_siena-02.webp'
  },
  {
    id: 'brisas',
    title: 'apartamentos en',
    title2: 'brisas y tocumen',
    subtitle: 'desde $95k',
    link: '/brisas-y-tocumen',
    imagePath: 'Proyectos/Este/Filia/Fotos_filia-18.webp'
  },
  {
    id: 'centro',
    title: 'apartamentos en el',
    title2: 'centro de la ciudad',
    subtitle: 'desde $125k',
    link: '/centro-ciudad',
    imagePath: 'Proyectos/Centro/Athas/Fotos_Athas-06.webp'
  },
  {
    id: 'este',
    title: 'casa en',
    title2: 'panamá este y norte',
    subtitle: 'desde $85k',
    link: '/casas-este',
    imagePath: 'Proyectos/Este/Provenza/Carrusel imágenes-04.webp'
  }
];
---

<Layout title="Haus Panama - Propiedades exclusivas en la ciudad de Panamá" fixedHeader={false}>
  <HeaderNonSticky />
  <ChatWrapper />

  <main class="font-helvetica w-full bg-white">
    <!-- HERO: Headline + 4 cards de zonas -->
    <section class="w-full px-5 lg:px-8 pt-3 pb-6 lg:pb-8 hero-section">
      <div class="max-w-[1312px] mx-auto w-full">
        <!-- Headline centrado -->
        <h1 id="hero-heading" class="anim-fade-up text-[#3a3a3c] font-bold text-2xl sm:text-3xl md:text-4xl lg:text-[48px] text-center leading-tight mb-3 lg:mb-4 max-w-[700px] mx-auto">
          un hogar bien pensado cambia la forma de vivir
        </h1>

        <!-- 4 Cards en fila horizontal -->
        <div id="cards-grid" class="grid grid-cols-2 lg:grid-cols-4 gap-3 lg:gap-4 items-stretch">
          {mainCards.map((card, index) => (
            <a
              href={card.link}
              class={`property-card interactive-element group flex flex-col h-full relative rounded-xl overflow-hidden border-2 border-[var(--primary)] transition-all duration-300 shadow-md hover:shadow-lg focus:outline-none focus:ring-2 focus:ring-[var(--primary)] anim-fade-up anim-card anim-delay-${index}`}
              tabindex="0"
              aria-label={`${card.title} ${card.title2} - ${card.subtitle}`}
            >
              <div class="relative w-full flex-1 aspect-[3/4] sm:aspect-[4/5] lg:aspect-[2/3]">
                <LocalImage
                  src={card.imagePath}
                  alt={`${card.title} ${card.title2}`}
                  className="absolute inset-0 w-full h-full object-cover transition-all duration-300 group-hover:scale-105"
                />
                <div class="absolute inset-0 bg-gradient-to-t from-black/80 via-black/30 to-transparent"></div>
                <div class="absolute bottom-0 left-0 right-0 p-3 sm:p-4">
                  <h3 class="text-[var(--primary)] text-sm sm:text-base lg:text-lg font-bold leading-tight">{card.title}</h3>
                  <h3 class="text-[var(--primary)] text-sm sm:text-base lg:text-lg font-bold leading-tight mb-2">{card.title2}</h3>
                  <div class="flex items-center gap-2 sm:gap-3 flex-wrap">
                    <p class="text-white text-xs sm:text-sm opacity-90">{card.subtitle}</p>
                    <span class="inline-block py-0.5 px-2 sm:py-1 sm:px-3 border border-white/80 text-white text-[10px] sm:text-xs font-medium rounded-md transition-all duration-300 group-hover:bg-[var(--primary)] group-hover:border-[var(--primary)]">
                      ver más
                    </span>
                  </div>
                </div>
              </div>
            </a>
          ))}
        </div>

        <!-- Botón Agenda una Visita -->
        <div id="visita-cta" class="anim-fade-up flex justify-center mt-5 lg:mt-6">
          <div class="relative" id="visita-dropdown-container">
            <button id="visita-toggle" class="group border-2 border-[var(--primary)] text-[var(--primary)] font-medium text-sm sm:text-base lg:text-lg px-8 py-3 rounded-[10px] text-center transition-all duration-300 hover:bg-[var(--primary)] hover:text-white flex items-center gap-2 cursor-pointer">
              agenda una visita
              <svg id="visita-arrow" xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="transition-transform duration-300"><path d="m7 7 10 10"/><path d="M17 7v10H7"/></svg>
            </button>
            <div id="visita-options" class="hidden absolute left-0 bottom-full mb-2 w-full min-w-[220px] rounded-[10px] border-2 border-[var(--primary)] bg-white overflow-hidden z-20 shadow-lg">
              <a href="https://wa.me/50763307851?text=%C2%A1Hola!%2C%20me%20gustar%C3%ADa%20agendar%20una%20visita%20en%20sus%20proyectos%20del%20area%20centro" data-area="centro" class="flex items-center gap-3 px-5 py-3 text-[#3a3a3c] font-medium text-sm hover:bg-[var(--primary)] hover:text-white transition-all duration-200 cursor-pointer">
                <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/><path stroke-linecap="round" stroke-linejoin="round" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
                área centro
              </a>
              <a href="https://wa.me/50763307851?text=%C2%A1Hola!%2C%20me%20gustar%C3%ADa%20agendar%20una%20visita%20en%20sus%20proyectos%20del%20area%20este" data-area="este" class="flex items-center gap-3 px-5 py-3 text-[#3a3a3c] font-medium text-sm hover:bg-[var(--primary)] hover:text-white transition-all duration-200 cursor-pointer">
                <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/><path stroke-linecap="round" stroke-linejoin="round" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
                área este
              </a>
              <a href="https://wa.me/50763307851?text=%C2%A1Hola!%2C%20me%20gustar%C3%ADa%20agendar%20una%20visita%20en%20sus%20proyectos%20del%20area%20oeste" data-area="oeste" class="flex items-center gap-3 px-5 py-3 text-[#3a3a3c] font-medium text-sm hover:bg-[var(--primary)] hover:text-white transition-all duration-200 cursor-pointer">
                <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/><path stroke-linecap="round" stroke-linejoin="round" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
                área oeste
              </a>
            </div>
          </div>
        </div>
      </div>
    </section>

    <AboutSection />
    <SocialFooter />
  </main>

  <!-- Modal: Agenda tu visita -->
  <div
    id="visita-modal"
    class="fixed inset-0 z-50 flex items-center justify-center p-4 hidden"
    role="dialog"
    aria-modal="true"
    aria-labelledby="modal-title"
  >
    <!-- Backdrop -->
    <div id="modal-backdrop" class="absolute inset-0 bg-black/50 backdrop-blur-sm"></div>

    <!-- Panel -->
    <div class="relative bg-white rounded-2xl shadow-2xl w-full max-w-md p-6 sm:p-8 z-10">
      <!-- Botón cerrar -->
      <button
        id="modal-close"
        type="button"
        class="absolute top-4 right-4 text-[#3a3a3c]/60 hover:text-[#3a3a3c] transition-colors duration-200 focus:outline-none focus:ring-2 focus:ring-[var(--primary)] rounded-lg p-1"
        aria-label="Cerrar modal"
      >
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
      </button>

      <!-- Encabezado -->
      <div class="mb-6">
        <p class="text-[var(--primary)] text-xs font-semibold uppercase tracking-widest mb-1">haus panama</p>
        <h2 id="modal-title" class="text-[#3a3a3c] text-2xl font-bold leading-tight">agenda tu visita</h2>
        <p class="text-[#3a3a3c]/60 text-sm mt-1">Te contactamos por WhatsApp para confirmar.</p>
      </div>

      <!-- Formulario -->
      <form id="visita-form" novalidate class="flex flex-col gap-4">
        <!-- Nombre -->
        <div class="flex flex-col gap-1">
          <label for="modal-name" class="text-[#3a3a3c] text-sm font-medium">Nombre completo</label>
          <input
            id="modal-name"
            name="name"
            type="text"
            autocomplete="name"
            placeholder="Ej: Juan Pérez"
            class="w-full border border-[#3a3a3c]/20 rounded-xl px-4 py-3 text-sm text-[#3a3a3c] placeholder-[#3a3a3c]/40 focus:outline-none focus:ring-2 focus:ring-[var(--primary)] focus:border-transparent transition-all duration-200"
          />
          <p id="modal-name-error" class="text-red-500 text-xs hidden" role="alert"></p>
        </div>

        <!-- Teléfono -->
        <div class="flex flex-col gap-1">
          <label for="modal-phone" class="text-[#3a3a3c] text-sm font-medium">Celular / WhatsApp</label>
          <input
            id="modal-phone"
            name="phone"
            type="tel"
            inputmode="tel"
            autocomplete="tel"
            placeholder="Ej: 6833-4554"
            class="w-full border border-[#3a3a3c]/20 rounded-xl px-4 py-3 text-sm text-[#3a3a3c] placeholder-[#3a3a3c]/40 focus:outline-none focus:ring-2 focus:ring-[var(--primary)] focus:border-transparent transition-all duration-200"
          />
          <p id="modal-phone-error" class="text-red-500 text-xs hidden" role="alert"></p>
        </div>

        <!-- Error global -->
        <p id="modal-global-error" class="text-red-500 text-sm hidden" role="alert"></p>

        <!-- Botón enviar -->
        <button
          id="modal-submit"
          type="submit"
          class="w-full bg-[var(--primary)] text-white font-semibold text-sm sm:text-base py-3 px-6 rounded-xl transition-all duration-200 hover:opacity-90 active:scale-[0.98] focus:outline-none focus:ring-2 focus:ring-[var(--primary)] focus:ring-offset-2 flex items-center justify-center gap-2 disabled:opacity-60 disabled:cursor-not-allowed"
        >
          <svg id="modal-submit-icon" xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="currentColor" class="flex-shrink-0"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347z"/><path d="M12 0C5.373 0 0 5.373 0 12c0 2.127.558 4.122 1.532 5.857L.057 23.882l6.196-1.453A11.942 11.942 0 0012 24c6.627 0 12-5.373 12-12S18.627 0 12 0zm0 21.818a9.792 9.792 0 01-5.002-1.369l-.358-.213-3.718.872.934-3.619-.234-.371A9.778 9.778 0 012.182 12C2.182 6.578 6.578 2.182 12 2.182S21.818 6.578 21.818 12 17.422 21.818 12 21.818z"/></svg>
          <span id="modal-submit-text">Abrir WhatsApp</span>
          <!-- Spinner (oculto por defecto) -->
          <svg id="modal-spinner" class="hidden animate-spin" xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 12a9 9 0 1 1-6.219-8.56"/></svg>
        </button>
      </form>
    </div>
  </div>
</Layout>

<style>
  /* Animaciones de entrada */
  .anim-fade-up {
    opacity: 0;
    transform: translateY(28px);
    transition: opacity 0.65s cubic-bezier(0.22, 1, 0.36, 1), transform 0.65s cubic-bezier(0.22, 1, 0.36, 1);
  }
  .anim-fade-up.anim-visible {
    opacity: 1;
    transform: translateY(0);
  }
  .anim-delay-0 { transition-delay: 0ms; }
  .anim-delay-1 { transition-delay: 100ms; }
  .anim-delay-2 { transition-delay: 200ms; }
  .anim-delay-3 { transition-delay: 300ms; }

  /* Reducir movimiento para usuarios que lo prefieran */
  @media (prefers-reduced-motion: reduce) {
    .anim-fade-up {
      opacity: 0;
      transform: none;
      transition: opacity 0.3s ease;
    }
  }

  .property-card.anim-visible:hover {
    transform: translateY(-5px);
    box-shadow: 0 12px 30px rgba(0, 0, 0, 0.15);
  }
</style>

<script>
  import { initPropertyCardInteractions } from '../services/interactions/propertyCardInteractions';
  document.addEventListener('DOMContentLoaded', initPropertyCardInteractions);

  document.addEventListener('DOMContentLoaded', () => {
    // --- Animaciones de entrada ---

    // Hero: h1 aparece inmediatamente al cargar
    const heroHeading = document.getElementById('hero-heading');
    if (heroHeading) {
      setTimeout(() => heroHeading.classList.add('anim-visible'), 50);
    }

    // Cards + botón CTA: Intersection Observer (scroll)
    const scrollTargets = document.querySelectorAll<HTMLElement>('.anim-card, #visita-cta');
    if (scrollTargets.length > 0) {
      const observer = new IntersectionObserver(
        (entries) => {
          entries.forEach((entry) => {
            if (entry.isIntersecting) {
              (entry.target as HTMLElement).classList.add('anim-visible');
              observer.unobserve(entry.target);
            }
          });
        },
        { threshold: 0.1 }
      );
      scrollTargets.forEach((el) => observer.observe(el));
    }

    // --- Lógica del dropdown de visita ---
    const toggle = document.getElementById('visita-toggle');
    const options = document.getElementById('visita-options');
    const arrow = document.getElementById('visita-arrow');
    const container = document.getElementById('visita-dropdown-container');

    if (!toggle || !options || !arrow) return;

    toggle.addEventListener('click', () => {
      const isOpen = !options.classList.contains('hidden');
      if (isOpen) {
        options.classList.add('hidden');
        arrow.classList.remove('-rotate-90');
      } else {
        options.classList.remove('hidden');
        arrow.classList.add('-rotate-90');
      }
    });

    document.addEventListener('click', (e) => {
      if (container && !container.contains(e.target as Node)) {
        options.classList.add('hidden');
        arrow.classList.remove('-rotate-90');
      }
    });

    // --- Modal: captura de datos antes de abrir WhatsApp ---

    // Estado del modal
    let pendingArea = '';
    let pendingWhatsappUrl = '';

    const modal         = document.getElementById('visita-modal') as HTMLDivElement | null;
    const backdrop      = document.getElementById('modal-backdrop') as HTMLDivElement | null;
    const modalClose    = document.getElementById('modal-close') as HTMLButtonElement | null;
    const form          = document.getElementById('visita-form') as HTMLFormElement | null;
    const nameInput     = document.getElementById('modal-name') as HTMLInputElement | null;
    const phoneInput    = document.getElementById('modal-phone') as HTMLInputElement | null;
    const nameError     = document.getElementById('modal-name-error') as HTMLParagraphElement | null;
    const phoneError    = document.getElementById('modal-phone-error') as HTMLParagraphElement | null;
    const globalError   = document.getElementById('modal-global-error') as HTMLParagraphElement | null;
    const submitBtn     = document.getElementById('modal-submit') as HTMLButtonElement | null;
    const submitText    = document.getElementById('modal-submit-text') as HTMLSpanElement | null;
    const submitIcon    = document.getElementById('modal-submit-icon') as SVGSVGElement | null;
    const spinner       = document.getElementById('modal-spinner') as SVGSVGElement | null;

    /** Abre el modal y mueve el foco al primer input */
    function openModal(area: string, whatsappUrl: string): void {
      if (!modal || !nameInput) return;
      pendingArea = area;
      pendingWhatsappUrl = whatsappUrl;
      modal.classList.remove('hidden');
      document.body.style.overflow = 'hidden';
      // Foco al primer campo tras el render
      requestAnimationFrame(() => nameInput.focus());
    }

    /** Cierra el modal y resetea el formulario */
    function closeModal(): void {
      if (!modal || !form) return;
      modal.classList.add('hidden');
      document.body.style.overflow = '';
      form.reset();
      clearErrors();
      setSubmitting(false);
    }

    /** Limpia todos los mensajes de error */
    function clearErrors(): void {
      if (nameError)   { nameError.textContent = '';  nameError.classList.add('hidden'); }
      if (phoneError)  { phoneError.textContent = ''; phoneError.classList.add('hidden'); }
      if (globalError) { globalError.textContent = ''; globalError.classList.add('hidden'); }
    }

    /** Muestra/oculta el estado de carga del botón */
    function setSubmitting(loading: boolean): void {
      if (!submitBtn || !submitText || !submitIcon || !spinner) return;
      submitBtn.disabled = loading;
      submitText.textContent = loading ? 'Enviando...' : 'Abrir WhatsApp';
      submitIcon.classList.toggle('hidden', loading);
      spinner.classList.toggle('hidden', !loading);
    }

    /** Valida los campos; retorna true si todo está OK */
    function validate(): boolean {
      let valid = true;
      clearErrors();

      const name = nameInput?.value.trim() ?? '';
      if (name.length < 3) {
        if (nameError) {
          nameError.textContent = 'El nombre debe tener al menos 3 caracteres.';
          nameError.classList.remove('hidden');
        }
        valid = false;
      }

      // Acepta 8 dígitos (Panamá), 507+8 dígitos, o formato internacional con + (7-15 dígitos)
      const rawPhone = phoneInput?.value ?? '';
      const digits = rawPhone.replace(/[\s\-()]/g, '');
      const localPanamaPattern = /^\d{8}$/;
      const internationalPattern = /^\+\d{7,15}$/;
      const panamaWithCodePattern = /^507\d{8}$/;
      if (
        !localPanamaPattern.test(digits) &&
        !internationalPattern.test(digits) &&
        !panamaWithCodePattern.test(digits)
      ) {
        if (phoneError) {
          phoneError.textContent = 'Ingresa un número de 8 dígitos (Ej: 6833-4554) o formato internacional (Ej: +50768334554).';
          phoneError.classList.remove('hidden');
        }
        valid = false;
      }

      return valid;
    }

    // Interceptar clicks en los enlaces de área para abrir el modal
    const areaLinks = options.querySelectorAll<HTMLAnchorElement>('a[data-area]');
    areaLinks.forEach((link) => {
      link.addEventListener('click', (e) => {
        e.preventDefault();
        // Cerrar el dropdown al abrir el modal
        options.classList.add('hidden');
        arrow.classList.remove('-rotate-90');
        openModal(link.dataset.area ?? '', link.href);
      });
    });

    // Cerrar con botón X
    modalClose?.addEventListener('click', closeModal);

    // Cerrar con click en el backdrop
    backdrop?.addEventListener('click', closeModal);

    // Cerrar con Escape
    document.addEventListener('keydown', (e: KeyboardEvent) => {
      if (e.key === 'Escape' && modal && !modal.classList.contains('hidden')) {
        closeModal();
      }
    });

    // Submit del formulario
    form?.addEventListener('submit', async (e: SubmitEvent) => {
      e.preventDefault();
      if (!validate()) return;

      setSubmitting(true);

      const name  = nameInput?.value.trim() ?? '';
      const phone = phoneInput?.value.trim() ?? '';

      try {
        const response = await fetch('/api/pipedrive-lead', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ area: pendingArea, name, phone }),
        });

        if (response.ok) {
          // Lead creado: abrir WhatsApp y cerrar modal
          window.open(pendingWhatsappUrl, '_blank', 'noopener,noreferrer');
          closeModal();
        } else {
          // Error del servidor: mostrar mensaje inline
          if (globalError) {
            globalError.textContent = 'No pudimos procesar tu solicitud, intenta de nuevo.';
            globalError.classList.remove('hidden');
          }
          setSubmitting(false);
        }
      } catch {
        // Error de red
        if (globalError) {
          globalError.textContent = 'No pudimos procesar tu solicitud, intenta de nuevo.';
          globalError.classList.remove('hidden');
        }
        setSubmitting(false);
      }
    });
  });
</script>
