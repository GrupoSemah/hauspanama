---
import Layout from '../layouts/Layout.astro';
import HeaderNonSticky from '../components/home/HeaderNonSticky.astro';
import SocialFooter from '../components/home/SocialFooter.astro';
import ChatWrapper from '../components/ChatWrapper.astro';
import AboutSection from '../components/home/AboutSection.astro';
import LocalImage from '../components/LocalImage.astro';

const mainCards = [
  {
    id: 'oeste',
    title: 'casas en',
    title2: 'panamá oeste',
    subtitle: 'desde $82k',
    link: '/casas-y-aptos-oeste',
    imagePath: 'Proyectos/Oeste/Siena/Fotos_siena-02.webp'
  },
  {
    id: 'brisas',
    title: 'apartamentos en',
    title2: 'brisas y tocumen',
    subtitle: 'desde $95k',
    link: '/brisas-y-tocumen',
    imagePath: 'Proyectos/Este/Filia/Fotos_filia-18.webp'
  },
  {
    id: 'centro',
    title: 'apartamentos en el',
    title2: 'centro de la ciudad',
    subtitle: 'desde $125k',
    link: '/centro-ciudad',
    imagePath: 'Proyectos/Centro/Athas/Fotos_Athas-06.webp'
  },
  {
    id: 'este',
    title: 'casa en',
    title2: 'panamá este y norte',
    subtitle: 'desde $85k',
    link: '/casas-este',
    imagePath: 'Proyectos/Este/Provenza/Carrusel imágenes-04.webp'
  }
];
---

<Layout title="Haus Panama - Propiedades exclusivas en la ciudad de Panamá" fixedHeader={false}>
  <HeaderNonSticky />
  <ChatWrapper />

  <main class="font-helvetica w-full bg-white">
    <!-- HERO: Headline + 4 cards de zonas -->
    <section class="w-full px-5 lg:px-8 pt-3 pb-6 lg:pb-8 hero-section">
      <div class="max-w-[1312px] mx-auto w-full">
        <!-- Headline centrado -->
        <h1 class="text-[#3a3a3c] font-bold text-2xl sm:text-3xl md:text-4xl lg:text-[48px] text-center leading-tight mb-3 lg:mb-4 max-w-[700px] mx-auto">
          un hogar bien pensado cambia la forma de vivir
        </h1>

        <!-- 4 Cards en fila horizontal -->
        <div class="grid grid-cols-2 lg:grid-cols-4 gap-3 lg:gap-4">
          {mainCards.map((card) => (
            <a
              href={card.link}
              class="property-card interactive-element group block relative rounded-xl overflow-hidden border-2 border-[var(--primary)] transition-all duration-300 shadow-md hover:shadow-lg focus:outline-none focus:ring-2 focus:ring-[var(--primary)]"
              tabindex="0"
              aria-label={`${card.title} ${card.title2} - ${card.subtitle}`}
            >
              <div class="relative w-full aspect-[3/4] sm:aspect-[4/5] lg:aspect-[2/3]">
                <LocalImage
                  src={card.imagePath}
                  alt={`${card.title} ${card.title2}`}
                  className="absolute inset-0 w-full h-full object-cover transition-all duration-300 group-hover:scale-105"
                />
                <div class="absolute inset-0 bg-gradient-to-t from-black/80 via-black/30 to-transparent"></div>
                <div class="absolute bottom-0 left-0 right-0 p-3 sm:p-4">
                  <h3 class="text-[var(--primary)] text-sm sm:text-base lg:text-lg font-bold leading-tight">{card.title}</h3>
                  <h3 class="text-[var(--primary)] text-sm sm:text-base lg:text-lg font-bold leading-tight mb-2">{card.title2}</h3>
                  <div class="flex items-center gap-2 sm:gap-3 flex-wrap">
                    <p class="text-white text-xs sm:text-sm opacity-90">{card.subtitle}</p>
                    <span class="inline-block py-0.5 px-2 sm:py-1 sm:px-3 border border-white/80 text-white text-[10px] sm:text-xs font-medium rounded-md transition-all duration-300 group-hover:bg-[var(--primary)] group-hover:border-[var(--primary)]">
                      ver más
                    </span>
                  </div>
                </div>
              </div>
            </a>
          ))}
        </div>

        <!-- Botón Agenda una Visita -->
        <div class="flex justify-center mt-5 lg:mt-6">
          <div class="relative" id="visita-dropdown-container">
            <button id="visita-toggle" class="group border-2 border-[var(--primary)] text-[var(--primary)] font-medium text-sm sm:text-base lg:text-lg px-8 py-3 rounded-[10px] text-center transition-all duration-300 hover:bg-[var(--primary)] hover:text-white flex items-center gap-2 cursor-pointer">
              agenda una visita
              <svg id="visita-arrow" xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="transition-transform duration-300"><path d="m7 7 10 10"/><path d="M17 7v10H7"/></svg>
            </button>
            <div id="visita-options" class="hidden absolute left-0 bottom-full mb-2 w-full min-w-[220px] rounded-[10px] border-2 border-[var(--primary)] bg-white overflow-hidden z-20 shadow-lg">
              <a href="https://wa.me/50763307851?text=%C2%A1Hola!%20Estoy%20interesado%20en%20proyectos%20del%20%C3%A1rea%20centro" target="_blank" rel="noopener noreferrer" class="flex items-center gap-3 px-5 py-3 text-[#3a3a3c] font-medium text-sm hover:bg-[var(--primary)] hover:text-white transition-all duration-200">
                <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/><path stroke-linecap="round" stroke-linejoin="round" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
                área centro
              </a>
              <a href="https://wa.me/50763307851?text=%C2%A1Hola!%20Estoy%20interesado%20en%20proyectos%20del%20%C3%A1rea%20este" target="_blank" rel="noopener noreferrer" class="flex items-center gap-3 px-5 py-3 text-[#3a3a3c] font-medium text-sm hover:bg-[var(--primary)] hover:text-white transition-all duration-200">
                <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/><path stroke-linecap="round" stroke-linejoin="round" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
                área este
              </a>
              <a href="https://wa.me/50763307851?text=%C2%A1Hola!%20Estoy%20interesado%20en%20proyectos%20del%20%C3%A1rea%20oeste" target="_blank" rel="noopener noreferrer" class="flex items-center gap-3 px-5 py-3 text-[#3a3a3c] font-medium text-sm hover:bg-[var(--primary)] hover:text-white transition-all duration-200">
                <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/><path stroke-linecap="round" stroke-linejoin="round" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
                área oeste
              </a>
            </div>
          </div>
        </div>
      </div>
    </section>

    <AboutSection />
    <SocialFooter />
  </main>
</Layout>

<style>
  .property-card:hover {
    transform: translateY(-5px);
    box-shadow: 0 12px 30px rgba(0, 0, 0, 0.15);
  }

  @media (min-width: 1024px) {
    .hero-section {
      min-height: calc(100vh - 80px);
    }
  }
</style>

<script>
  import { initPropertyCardInteractions } from '../services/interactions/propertyCardInteractions';
  document.addEventListener('DOMContentLoaded', initPropertyCardInteractions);

  document.addEventListener('DOMContentLoaded', () => {
    const toggle = document.getElementById('visita-toggle');
    const options = document.getElementById('visita-options');
    const arrow = document.getElementById('visita-arrow');
    const container = document.getElementById('visita-dropdown-container');

    if (!toggle || !options || !arrow) return;

    toggle.addEventListener('click', () => {
      const isOpen = !options.classList.contains('hidden');
      if (isOpen) {
        options.classList.add('hidden');
        arrow.classList.remove('-rotate-90');
      } else {
        options.classList.remove('hidden');
        arrow.classList.add('-rotate-90');
      }
    });

    document.addEventListener('click', (e) => {
      if (container && !container.contains(e.target as Node)) {
        options.classList.add('hidden');
        arrow.classList.remove('-rotate-90');
      }
    });
  });
</script>
