---
import Layout from '../../layouts/Layout.astro';
import HeaderNonSticky from '../../components/home/HeaderNonSticky.astro';
import SocialFooter from '../../components/home/SocialFooter.astro';
import ChatWrapper from '../../components/ChatWrapper.astro';
import ProjectCard from '../../components/ProjectCard.astro';

const proyectos = [
  {
    name: "Solaris",
    href: "/solaris",
    coverImage: "/Proyectos/Oeste/Solaris/PRODUCTO/Carrusel-Producto Solaris-01.webp",
    logoWhite: "/Portadas/Logo Solaris - blanco.svg",
    price: "$120,000",
    locationBold: "hato montaña / arraijan",
    locationDetail: "a 5 min del Machetazo - Olimpia",
    preVenta: true,
  },
  {
    name: "Siena",
    href: "/siena",
    coverImage: "/Proyectos/Oeste/Siena/PRODUCTO/Carrusel-Producto Siena-01.webp",
    logoWhite: "/Portadas/Logo_Siena_-_blanco_zodyyk.svg",
    price: "$113,000",
    locationBold: "hato montaña / arraijan",
    locationDetail: "a 6 min de la panamericana",
  },
  {
    name: "Verona",
    href: "/verona",
    coverImage: "/Proyectos/Oeste/Verona/PRODUCTO/Carrusel-producto verona-01.webp",
    logoWhite: "/Portadas/Logo_Verona_-_blanco_rdwfze.svg",
    price: "$82,000",
    locationBold: "hato montaña / arraijan",
    locationDetail: "entrando por el machetazo",
  },
  {
    name: "Piamonte",
    href: "/piamonte",
    coverImage: "/Proyectos/Oeste/Piamonte/PRODUCTO/Carrusel-Producto Piamonte-01.webp",
    logoWhite: "/Portadas/Logo_Piamonte_-_blanco_sudxvt.svg",
    price: "$120,000",
    locationBold: "hato montaña / arraijan",
    locationDetail: "frente al parque hato montaña",
  },
];
---

<Layout title="Casas en Panamá Oeste | Haus Panama" fixedHeader={false}>
  <HeaderNonSticky />
  <ChatWrapper />

  <main class="font-helvetica w-full bg-white">
    <section class="w-full px-5 lg:px-8 pt-10 lg:pt-16 pb-16 lg:pb-24">
      <div class="max-w-[1312px] mx-auto">
        <h2 class="text-[#3a3a3c] font-bold text-2xl sm:text-3xl lg:text-4xl xl:text-[42px] leading-tight mb-8 lg:mb-10">
          casas en panamá oeste
        </h2>
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6 lg:gap-8">
          {proyectos.map((project) => (
            <ProjectCard {...project} />
          ))}
        </div>
      </div>
    </section>
  </main>

  <SocialFooter />
</Layout>
