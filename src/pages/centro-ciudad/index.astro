---
import Layout from '../../layouts/Layout.astro';
import HeaderNonSticky from '../../components/home/HeaderNonSticky.astro';
import SocialFooter from '../../components/home/SocialFooter.astro';
import ChatWrapper from '../../components/ChatWrapper.astro';
import ProjectCard from '../../components/ProjectCard.astro';

const proyectos = [
  {
    name: "Áthas",
    href: "/athas",
    coverImage: "/Proyectos/Centro/Athas/PRODUCTO/Carrusel-Producto Athas-01.webp",
    logoWhite: "/Portadas/Logo_Athas_-_blanco_diizlt.svg",
    price: "$125,000",
    locationBold: "12 de octubre / av. la pulida",
    locationDetail: "a 5min del KFC",
  },
  {
    name: "Astre",
    href: "https://astrepanama.com",
    coverImage: "/Proyectos/Centro/Astre/Diseno_Imagenes-06.webp",
    logoWhite: "/Portadas/Logo Astre - blanco.svg",
    price: "$250,000",
    locationBold: "calle 75 / vía israel",
    locationDetail: "acceso directo a corredor sur",
  },
  {
    name: "Alai",
    href: "/alai",
    coverImage: "/Proyectos/Centro/Alai/PRODUCTO/Carrusel-Producto Alai-01.webp",
    logoWhite: "/Portadas/Logo_Alai_-_blanco_xunsmh.svg",
    price: "$140,000",
    locationBold: "vía españa",
    locationDetail: "frente al hospital san fernando",
  },
];
---

<Layout title="Apartamentos en el Centro | Haus Panama" fixedHeader={false}>
  <HeaderNonSticky />
  <ChatWrapper />

  <main class="font-helvetica w-full bg-white">
    <section class="w-full px-5 lg:px-8 pt-10 lg:pt-16 pb-16 lg:pb-24">
      <div class="max-w-[1312px] mx-auto">
        <h2 class="text-[#3a3a3c] font-bold text-2xl sm:text-3xl lg:text-4xl xl:text-[42px] leading-tight mb-8 lg:mb-10">
          apartamentos en el centro de la ciudad
        </h2>
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6 lg:gap-8">
          {proyectos.map((project) => (
            <ProjectCard {...project} />
          ))}
        </div>
      </div>
    </section>
  </main>

  <SocialFooter />
</Layout>
